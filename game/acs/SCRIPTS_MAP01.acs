script 29 (void) //teleport minotaur to nearest teleporter if he is too far from the player(script activator)
{
	int closest;
	int mindist = 800;
	int a;
	int b;
	int c;
	delay(35);
	if (!poleflag) print (s:"RUN!");
	while(GetActorProperty (198, APROP_Health)>1) //While minotaur alive
	{
		//print (s:"delay 10 seconds");
		delay(490);
		//print (s:"begin script");			//wait 10 seconds to prevent runaway script
		if (distance2D(198, 0) > mindist )  //(distance between minotaur and player - player TID defined in ENTER script)
		{
			a = distance2D (0, 107); //calculate teleporter a distance from player
			b = distance2D (0, 196); //calculate teleporter b distance from player
			c = distance2D (0, 197); //calculate teleporter c distance from player
			closest = min(a,b,c); 	 //Determine which teleporter is closest

			//Teleport minotaur to teleporter nearest to player
			if (a == closest)
			{
				TeleportOther(198,107,0);
				//HudMessage(s:"teleporting to a (maze exit)";HUDMSG_PLAIN,CR_GOLD, 0, 1.7,0.8,5.0,0.05,2.0 );
			}
			else if (b == closest)
			{
				TeleportOther(198,196,0);
				//HudMessage(s:"teleporting to B (blue key)";HUDMSG_PLAIN,CR_GOLD, 0, 1.8,0.8,5.0,0.05,2.0 );
			}
			else if (c == closest)
			{
				TeleportOther(198,197,0);
				//HudMessage(s:"teleporting to c (maze entrance)";HUDMSG_PLAIN,CR_GOLD, 0, 1.9,0.8,5.0,0.05,2.0 );
			}

		}
	}
	//HudMessage(s:"He died. Good job! Script Terminated";HUDMSG_PLAIN,CR_GOLD, 0, 2.1,0.8,5.0,0.05,2.0 );  //test script terminated correctly
}

