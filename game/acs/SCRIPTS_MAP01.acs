script 19 (void) //flick fuse open prison gate
{
	Light_RaiseByValue(152,50);
	Light_RaiseByValue(151,86);
	SetLineTexture(153,LINE_FRONT,TEXTURE_MIDDLE, "-");
	Line_SetBlocking(153,0,BLOCKF_PLAYERS);
	Line_SetBlocking(153,0,BLOCKF_PROJECTILES);
	Line_SetBlocking(153,0,BLOCKF_HITSCAN);
	Line_SetBlocking(153,0,BLOCKF_SOUND);
	SoundSequence("fusebox");
	Light_Flicker(177,210,160);
	Thing_Deactivate(206);
	{
		Light_ChangeToValue (177, 210);
		Light_ChangeToValue (192, 160);
		delay (random (0, 1) * 64 + 1);
		while (1)
		{
			Light_ChangeToValue (177, 160);
			Light_ChangeToValue (192, 112);
			delay (random (1,7));
			Light_ChangeToValue (177, 210);
			Light_ChangeToValue (192, 160);
			delay (random (1,23));
		}
	  }
}

