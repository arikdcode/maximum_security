	if (CheckActorFloorTexture(1001, "slime15"))
		{
			delay(105);
			HudMessage(s:"Ten months in prison... will it ever end?";HUDMSG_PLAIN,CR_GOLD, 0, 1.5,0.8,5.0,0.05,2.0 );
