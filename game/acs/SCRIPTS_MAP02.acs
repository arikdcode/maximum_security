script "PowerRoomPuzzle" OPEN
{
	int mentioned_floor = 0;
	while(1)
	{
		delay(35);
		if (switch1 && switch2 && !switch3 && switch4 && !broken)
		{

			Floor_LowerByValue(15,4,1);
			Floor_LowerByValue(14,4,40);
			Ceiling_RaiseByValue(14,4,40);
			changefloor(15,"OTECHB05");
			Light_Glow(15,224,128,12);
			delay(75);
			Floor_RaiseByValue(21,2,52);
			Ceiling_RaiseByValue(21,2,92);
			switch1 = 3;
			switch2 = 3;
			switch3 = 3;
			switch3 = 3;
			switch4 = 3;
			bluepower = 1;
			delay(135);
			break;
		}

		else if (switch1 && switch2 && !switch3 && switch4 && broken && !mentioned_floor)
		{
			delay(35);
			log(s:"Almost have it... but that broken section... Hmm...");
			mentioned_floor = 1;
		}
		else delay(1);

	}
}
