script 3 (void) //start switch
{
	Light_RaiseByValue(23,24);
	Ceiling_RaiseByValue(5,8,6);
	Light_Glow(6,224,128,12);
	Floor_LowerByValue(6,8,1);
	changefloor(6,"OTECHB05");
	Light_Glow(6,224,128,12);
	Light_Glow(5,224,128,12);
	ToggleFloor7();
	Light_RaiseByValue(18,120);
	ToggleFloor19();
	changefloor(24,"OIRONL81");

	SetLineTexture(25,SIDE_FRONT,TEXTURE_BOTTOM, "OIRONL81");
	Thing_Activate(26);

		while(broken)
	{
		Floor_RaiseByValue(16,32,6);
		Floor_RaiseByValue(27,32,6);
		delay(18);
		Floor_LowerByValue(16,32,6);
		Floor_LowerByValue(27,32,6);
		delay(18);
		Floor_RaiseByValue(16,32,6);
		Floor_RaiseByValue(27,32,6);
		delay(12);
		Floor_LowerByValue(16,32,6);
		Floor_LowerByValue(27,32,6);
		delay(35);
		Floor_RaiseByValue(16,4,2);
		Floor_RaiseByValue(27,4,2);
		delay(6);
		SoundSequenceOnSector(22,"Whirrstop",SECSEQ_INTERIOR);
		Floor_LowerByValue(16,4,2);
		Floor_LowerByValue(27,4,2);
		delay(70);
	}
}

