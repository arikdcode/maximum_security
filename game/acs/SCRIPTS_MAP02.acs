function void Switch_L (void)
{
	if(!bluepower) log(s:"Looks like there is no power.");
	else
	{
		toggle35();
		toggle33();
		toggle34();
	}
}

int floor34 = 0;
int floor33 = 0;
int floor35 = 1;

function void toggle34 (void) //toggle bars in puzzle
{
	if (floor34) Ceiling_Lowerbyvalue(34,100,128);
	else Ceiling_Raisebyvalue(34,100,128);

	if (floor34 == 0) floor34 = 1;
	else floor34 = 0;
}

function void toggle35 (void) //toggle bars in puzzle
{
	if (floor35) Ceiling_LowerByValue(35,100,128);
	else Ceiling_Raisebyvalue(35,100,128);

	if (floor35 == 0) floor35 = 1;
	else floor35 = 0;
}


function void toggle33 (void) //toggle bars in puzzle
{
	if (floor33) Ceiling_Lowerbyvalue(33,100,128);
	else Ceiling_Raisebyvalue(33,100,128);

	if (floor33 == 0) floor33 = 1;
	else floor33 = 0;
}


function void Switch_M (void)
{
	if(!bluepower) log(s:"Looks like there is no power.");
	else
	{
		toggle34();
		toggle35();
	}
}

function void Switch_R (void)
{
	if(!bluepower) log(s:"Looks like there is no power.");
	else
	{
		toggle33();
		toggle34();
	}

}

