script 26 (void) //Boss Fight arch vile resurrect
{
	log(s:"Where the hell am I?");
	while (GetActorProperty(125,APROP_Health) > 0) //While secret hidden arch-Vile is alive
	{
		delay(350); //wait 10 seconds
		//log(s:"check");
		if (GetActorProperty(126, APROP_HEALTH) < 1 && GetActorProperty(125,APROP_Health) > 0)
		{
			Thing_Raise(126,1); //heal and resurrect borther 1
			log(s:"Something is bringing them back!");
			SoundSequenceOnSector(128,"VileLaugh",SECSEQ_FULLHEIGHT);

		}

		//log(s:"brother 1 hp is ", i:GetActorProperty(126, APROP_HEALTH));

		if (GetActorProperty(127, APROP_HEALTH) < 1 && GetActorProperty(125,APROP_Health) > 0)
		{
			Thing_Raise(127,1); //heal and resurrect borther 2
			log(s:"Something is bringing them back!");
			SoundSequenceOnSector(128,"VileLaugh",SECSEQ_FULLHEIGHT);

		}
	}
	log(s:"The resurrector is dead.");

	while (GetActorProperty(127, APROP_HEALTH) > 0 || GetActorProperty(126, APROP_HEALTH) > 0 || GetActorProperty(125,APROP_Health) > 0)
	{
			delay(35);
	}

		Floor_RaiseByValue(131,8,96);
		Floor_RaiseByValue(132,8,64);
		log(s:"Finally...");
		delay(70);
