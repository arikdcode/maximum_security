#include "zcommon.acs"

int seconds = 35;
int broken = 1;
int bluepower = 0; //should be zero before start actual map

script 1 OPEN
{
	do
	{
		delay(350);
		if(bluepower == 1)
		{
			//delay(35);
			Thing_Activate(32); //turn on pillar glow lights

			ChangeFloor(37, "DROBSD25");
			ChangeCeiling(37, "DROBSD23");
			Light_RaiseByValue(37,36);

			Thing_Activate(28); //turn on reactor light
			Floor_LowerByValue(29,8,1); //link power circuit to switches
			changefloor(29,"OTECHB05"); //circuit tex
			Light_Glow(29,224,104,12); //circuit glow
			//Light_RaiseByValue(31,40); //brighten switch room
			delay(35);
			thing_activate(36); //Reactor hum
			thing_activate(37); //don't remember
			delay(15);
			//delay(20*seconds);
			break;
		}

	}
	while(bluepower == 0);
	log(s:"Looks like the power is back on.");

}


Script 2 (void)
{
	Polyobj_DoorSlide(1,4,128,45,200);
	Polyobj_DoorSlide(2,4,0,45,200);
}


//Puzzle blue power room------------------------------------------
