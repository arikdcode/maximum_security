//Music Box Room------------------------------------------------------
//int music;
int musictime = 20;
int viletrap = 0;

int orangeBook_inventory = 0; //70 isecor //
int greenBook_inventory = 0; //69		//
int blueBook_inventory = 0; //67		//
int redBook_inventory = 0; //68			//

int book_count = 4;

int Books_placed = 0;


function void musicBox (int music) //deprecated
{
	//int music = x;
	//if (music == 0) music = 1;
	//else music = 0;

	switch(music)
	{
		case 0:
		{
			thing_deactivate(41);
			log(s:"Musicbox is off");
		}


		case 1:
		{
			thing_activate(41);
			log(s:"Musicbox is on");

		}

		default:
		{
			log(s:"Haunting...");
		}
	}
}
script 14 (void)
{
	if (viletrap == 0) //reveal arch-viles the first time the musicbox is activated
	{
		door_open(45,128,0);
		viletrap++;
	}

	if (musictime > 1) // if musicbox is not running already, turn it on
		{
			thing_activate(41); //turn on music
			Floor_Waggle(46,10,20,0,20*seconds); //musicbox animation
			Floor_Waggle(47,12,30,0,20*seconds);
			Floor_Waggle(48,14,40,0,20*seconds);
			log(s:"Musicbox is on");

			//reveal books that aren't grabbed
			if (orangeBook_inventory == 0)
			{
				FloorAndCeiling_RaiseByValue(70,1024,400);
				Thing_SetSpecial(145,1,0,4,240);
				//Light_glow(44,256,128,35);
			}

			if (greenBook_inventory == 0)
			{
				FloorAndCeiling_RaiseByValue(69,1024,400);
				Thing_SetSpecial(146,1,0,4,250);
			}

			if (redBook_inventory == 0)
			{
				FloorAndCeiling_RaiseByValue(68,1024,400);
				Thing_SetSpecial(147,1,0,4,250);
			}

			if (blueBook_inventory == 0)
			{
				FloorAndCeiling_RaiseByValue(67,1024,400);
				Thing_SetSpecial(148,1,0,4,250);
			}


			while (musictime > 12) //reveal monsters and freeze for 8 seconds
				{
					log(i:musictime);
					delay(35);
					musictime--;

				}

			thing_activate(52); //unfreeze monsters and begin chase!
			thing_activate(53);
			thing_activate(54);
			thing_activate(55);

			// Teleport 2 of the  monsters to upper level if player is there
			if ((GetActorZ(0) >> 16) > ((GetActorZ(52) >> 16)-60)) TeleportOther(52,56,0);
			if ((GetActorZ(0) >> 16) > ((GetActorZ(54) >> 16 ) -60)) TeleportOther(54,58,0);



			//Teleport the same 2 of the monsters to lower level if player is there
			if ((GetActorZ(0) >> 16) < ((GetActorZ(52) >> 16) -60)) TeleportOther(52,61,0);
			if ((GetActorZ(0 >> 16)) < ((GetActorZ(53) >> 16) - 60 )) TeleportOther(53,62,0);

			while (musictime > 0) //12 seconds of being chased
				{
					log(i:musictime);
					delay(35);
					musictime--;

				}

			log(i:musictime);
			musictime = 20; //reset timer

			//hide books that aren't grabbed
			if (orangeBook_inventory == 0)
			{
				FloorAndCeiling_LowerByValue(70,1024,400);
				Thing_SetSpecial(145,1,0,4,255);
			}

			if (greenBook_inventory == 0)
			{
				FloorAndCeiling_LowerByValue(69,1024,400);
				Thing_SetSpecial(146,1,0,4,255);
			}

			if (redBook_inventory == 0)
			{
				FloorAndCeiling_LowerByValue(68,1024,400);
				Thing_SetSpecial(147,1,0,4,255);
			}

			if (blueBook_inventory == 0)
			{
				FloorAndCeiling_LowerByValue(67,1024,400);
				Thing_SetSpecial(148,1,0,4,255);
			}



	}

	Thing_Deactivate(41);  //freeze monsters again while music is off
	thing_Deactivate(52);
	thing_Deactivate(53);
	thing_Deactivate(54);
	thing_Deactivate(55);
	log(s:"Musicbox is off");
}



script 15 (void) //green book
{
	FloorAndCeiling_LowerByValue(69,1024,400);
	Thing_SetSpecial(146,1,0,4,255);
	greenBook_inventory = 1;
	if (book_count == 4) log(s:"I have the first book! ");
	else if (book_count < 2) log(s:"I have all the books!");
	else log(i:book_count-1, s:" left to go!");
	book_count--;
}

