function void togglefloor10 (void)
{
	if (floor10 == 0) floor10 = 1;
	else floor10 = 0;

	switch(floor10)
	{

	case 1 :
	Floor_RaiseByValue(10,32,97);
	break;

	case 0:
	Floor_LowerByValue(10,32,97);
	break;

	default: //If the number is neither 0 or 1, then this block is executed.
	log(s:"Hmm...");
	break;
	}
}

