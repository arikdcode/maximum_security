function void openCeiling14 (void)
{
	if (!Ceiling14)
	{
		ceiling14 = 1;
		Ceiling_RaiseByValue(14,8,16);
		Light_Glow(14,224,128,12);
	}
}

function void closeCeiling14 (void)
{
	if (ceiling14)
	{
		ceiling14 = 0;
		Ceiling_LowerByValue(14,8,16);
		Light_Glow(14,104,128,12);
	}
}


function void switchLight12 (void)
{
		if (switch1 && switch2) Light_Glow(13,224,128,12);
		else Light_Glow(13,128,104,12);
}

function void switchLight124  (void)
{
		if (switch1 && switch2 && switch4)
		{
			Light_Glow(20,224,128,12);
			OpenCeiling14();
		}
		else if (!switch1 || !switch2 || !switch3)
		{

			Light_Glow(20,104,128,12);
			CloseCeiling14();
		}
}


function void switch_F1 (void)
{
		If (switch1 == 1) switch1 = 0;
		else if (switch1 == 0) switch1 = 1;
		switch(switch1)
		{
		case 1:
			changefloor(9,"OTECHB05");
			Light_Glow(9,224,128,12);
			switchlight12(); //check switches are on and make floor glow
			switchLight124();
			Floor_LowerByValue(9,8,1);
			ToggleFloor19();
			ToggleFloor10();
			break;

		case 0:
			changefloor(9,"OIRONL81");
			Light_Glow(9,104,128,12);
			switchlight12();
			switchLight124();
			Floor_RaiseByValue(9,8,1);
			ToggleFloor19();
			ToggleFloor10();
			break;

		default: //If the number is neither 0 or 1, then this block is executed.
		log(s:"Hmm...");
		break;
		}
}

function void switch_F2 (void)
{
	If (switch2 == 1) switch2 = 0;
  else if (switch2 == 0) switch2 = 1;

  switch(switch2)
  {
  case 1:
	changefloor(13,"OTECHB05");
	switchlight12();
	switchLight124();
	Floor_LowerByValue(13,8,1);
	ToggleFloor12();
    break;

  case 0:
	changefloor(13,"OIRONL81");
	Light_Glow(13,128,12,12);
	switchlight12();
	switchLight124();
	Floor_RaiseByValue(13,8,1);
	ToggleFloor12();
    break;

  default: //If the number is neither 0 or 1, then this block is executed.
    log(s:"Hmm...");
    break;
  }
}

function void switch_F3 (void)
{
	If (switch3 == 1) switch3 = 0;
	else if (switch3 == 0) switch3 = 1;

	switch(switch3)
	{
	case 1:
		changefloor(15,"OTECHB05");
		switchlight12();
		switchLight124();
		ToggleFloor17();
		break;

	case 0:
		changefloor(15,"OIRONL81");
		switchlight12();
		switchLight124();
		ToggleFloor17();
		break;

	default: //If the number is neither 0 or 1, then this block is executed.
		log(s:"Hmm...");
		break;
	}
}

function void switch_F4 (void)
{
	if (switch4 ==1) switch4 = 0;
	else if (switch4 == 0) switch4 = 1;

	switch(switch4)
	{
		Case 1:
			changefloor(20,"OTECHB05");
			switchLight124();
			Floor_LowerByValue(20,8,1);
			ToggleFloor10();
			break;


		Case 0:
			changefloor(20,"OIRONL81");
			switchLight124();
			Floor_RaiseByValue(20,8,1);
			ToggleFloor10();
			break;

		default: //If the number is neither 0 or 1, then this block is executed.
		log(s:"Hmm...");
		break;
	}

}


