int fake_trapped = 0;
script 28 (void) //fake death corridor
{
	if (!fake_trapped)
	{
	Sector_SetColor(89,255,100,100);
	Sector_SetColor(90,255,100,100);
	Sector_SetColor(91,255,100,100);
	Sector_SetColor(92,255,100,100);
	Sector_SetColor(93,255,100,100);
	Sector_SetColor(94,255,100,100);
	Sector_SetColor(95,255,100,100);
	Sector_SetColor(106,255,100,100);

	Floor_RaiseAndCrush(89,16,100,0);
	delay(60);
	Floor_RaiseAndCrush(90,16,100,0);
	delay(60);
	Floor_RaiseAndCrush(91,16,100,0);
	delay(60);
	Floor_RaiseAndCrush(92,16,100,0);
	delay(60);
	Floor_RaiseAndCrush(93,16,100,0);
	delay(60);
	Floor_RaiseAndCrush(94,16,100,0);
	delay(60);
	Floor_RaiseByValue(95,4,64);
	Radius_Quake(6,120,0,64,0);
	delay(180);
	Floor_lowerByValue(95,4,64);
	delay(60);
	Door_Open(88,4,0);

	Sector_SetColor(89,255,255,255);
	Sector_SetColor(90,255,255,255);
	Sector_SetColor(91,255,255,255);
	Sector_SetColor(92,255,255,255);
	Sector_SetColor(93,255,255,255);
	Sector_SetColor(94,255,255,255);
	Sector_SetColor(95,255,255,255);
	Sector_SetColor(106,255,255,255);

	Floor_LowerToLowest(89,8);
	Floor_LowerToLowest(90,8);
	Floor_LowerToLowest(91,8);
	Floor_LowerToLowest(92,8);
	Floor_LowerToLowest(93,8);
	Floor_LowerToLowest(94,8);
	Floor_LowerToLowest(95,8);
	fake_trapped = 1;
	}
	else Door_Open(88,4,0);

}
int  trap_on = 1;
int red97 = 1;
script "colorTrap" ENTER //forcefield puzzle (red/blue))
{
	while(trap_on)
	{
		Sector_SetColor(97,255,100,100,0);
		ChangeCeiling(97,"0LGHTE06");
		Sector_SetDamage(97,20,15,8, 256);
		Sector_SetColor(98,100,100,255,0);
		ChangeCeiling(98,"0LGHTE05");
		Sector_SetDamage(98,0,15,8, 256);
		PlaySound(99,"STONESTP",CHAN_AUTO,1.0,FALSE,ATTN_NORM);
		delay(35);

		Sector_SetColor(100,100,100,255,0);
		ChangeCeiling(100,"0LGHTE05");
		Sector_SetDamage(100,0,15,8, 256);
		PlaySound(152,"STONESTP",CHAN_AUTO,1.0,FALSE,ATTN_NORM);

		delay(35);
		Sector_SetColor(100,255,100,100,0);
		ChangeCeiling(100,"0LGHTE06");
		Sector_SetDamage(100,20,15,8, 256);
		PlaySound(152,"STONESTP",CHAN_AUTO,1.0,FALSE,ATTN_NORM);



		Sector_SetColor(98,255,100,100,0);
		ChangeCeiling(98,"0LGHTE06");
		Sector_SetDamage(98,20,15,8,256);
		Sector_SetColor(97,100,100,255,0);
		ChangeCeiling(97,"0LGHTE05");
		Sector_SetDamage(97,0,15,8,256);
		PlaySound(99,"STONESTP",CHAN_AUTO,1.0,FALSE,ATTN_NORM);
		delay(70);

	}
}

