int stage2 = 1;
int stage3 = 1;
int stage4 = 1;
script 51 (void) //death knight Spawn and fight
{
	if (deathknight_sent && deathknight_alive)

	{
		StartConversation(171,1);
		stopsound(169,chan_auto);
		int x = GetActorX(169);
		int y = GetActorY(169);
		int z = GetActorZ(169);
		thing_remove(171);

		Thing_remove(169);
		spawn("DeathKnightBoss",x,y,z,169,180);
		delay(15);
		Thing_Activate(172);
		Light_RaiseByValue(170,100);
		SetMusic("SYNTDUES");
		floor_lowerbyValue(173,16,32);


		while(deathknight_alive)
		{
			while (GetActorProperty(169,APROP_Health) > 4000) delay(70); //stage 0
			if(stage1) //stage1
			{
				//log(s:"Stage 1");
				Door_close(160, 32,0);
				thing_deactivate(169);
				SetLineTexture(176,SIDE_FRONT,TEXTURE_MIDDLE,"OBASEL3A");
				SetLineTexture(178,SIDE_BACK,TEXTURE_TOP,"OBASEL3A");

				Light_RaiseByValue(170,48);
				Light_Glow(174,256,112,35);
				changefloor(174,"0CONCH01");
				Floor_LowerByValue(174,64,9);
				PlaySound(0,"CRACKLE",CHAN_AUTO,1.0,0,0);
				radius_quake(2,70,0,512,0);
				delay(140);
				Floor_LowerByValue(174,256,1024);
				PlaySound(0,"CONBREAK",CHAN_AUTO,1.0,0,0);
				sector_setdamage(174,1000,17,1,256);
				delay(35);

				Ceiling_RaiseByValue(170,64,1024);
				delay(70);
				Floor_RaiseByValue(175,64,512);
				delay(70);
				Floor_RaiseToLowestCeiling(177,32);
				Sector_SetDamage(177,20,15,16,256);

				ACS_Execute(52,0); //trigger lightning script

				ACS_Execute(54,0); //spawn health and ammo
				delay(35);
				thing_activate(169);
				teleportOther(169,183,0);
				delay(145);
				ChangeCeiling(174,"0LLLLA03");

				while (GetActorProperty(169,APROP_Health) > 3000)
				{
					delay(35);
					if((getactorZ(0)>>16) < -96 && (GetActorProperty(0,APROP_Health)) > 0) playsound(0,"WILHELM",CHAN_AUTO,1.0,0,0);
				}
				stage1 = 0;
			}

			if(stage2) //stage2
			{
			//log(s:"Stage 2");


				thing_deactivate(169);
				changefloor(184,"0GRATC01");
				Floor_RaiseByValue(184,8,32);
				Ceiling_RaiseByValue(170,32,512);
				delay(35);
				ACS_Execute(53,0); //spawn items
				Floor_LowerByValue(185,8,8);
				Floor_LowerByValue(186,8,16);
				Floor_LowerByValue(187,8,24);
				Floor_LowerByValue(188,8,32);
				Floor_LowerByValue(189,8,40);
				Floor_LowerByValue(190,8,48);
				changefloor(185,"0LLLLA04");
				changefloor(186,"0LLLLA04");
				changefloor(187,"0LLLLA04");
				changefloor(188,"0LLLLA04");
				changefloor(189,"0LLLLA04");
				changefloor(190,"0LLLLA04");
				delay(35);
				NoiseAlert(0,195);
				Floor_LowerToLowest(177, 64);
				delay(70);
				Floor_RaiseToLowestCeiling(196,32);
				teleportOther(169,183,0);
				thing_activate(169);
				teleportOther(169,183,0);
				Floor_RaiseByValue(202,16,64);



				while (GetActorProperty(169,APROP_Health) > 2000)
				{
					delay(35);
					if((getactorZ(0)>>16) < 300 && (GetActorProperty(0,APROP_Health)) > 0) playsound(0,"WILHELM",CHAN_AUTO,1.0,0,0);
				}
				stage2 = 0; //stop lightning script

				}

			if (stage3) //stage 3

			{
				//log(s:"Stage 3");
				thing_deactivate(169);
				SetMusicVolume(0.8);
				delay(15);
				SetMusicVolume(0.6);
				delay(15);
				SetMusicVolume(0.4);
				delay(15);
				SetMusicVolume(0.2);
				delay(15);


				NoiseAlert(0,203);

				SetMusic("DOPHONIC");
				delay(5);
				SetMusicVolume(1.0);

				Ceiling_RaiseByValue(170,32,512);
				delay(35);
				Floor_RaiseByValue(185,8,16);
				Floor_RaiseByValue(186,8,24);
				Floor_RaiseByValue(187,8,32);
				Floor_RaiseByValue(188,8,40);
				Floor_RaiseByValue(189,8,48);
				Floor_RaiseByValue(190,8,52);

				delay(35); //pitfall 2
				changefloor(184,"0CONCH01");
				Floor_LowerByValue(174,64,8);
				radius_quake(1,10,0,512,0);
				PlaySound(0,"CRACKLE",CHAN_AUTO,1.0,0,0);
				delay(35);
				radius_quake(1,10,0,512,0);
				PlaySound(0,"CRACKLE",CHAN_AUTO,1.0,0,0);
				delay(35);
				radius_quake(1,10,0,512,0);
				PlaySound(0,"CRACKLE",CHAN_AUTO,1.0,0,0);
				delay(35);
				Floor_LowerByValue(184,32,512);
				radius_quake(2,35,0,512,0);
				delay(35);
				Sector_SetDamage(184,1000,17,1,256);
				thing_Activate(169);
				teleportOther(169,183,0);
				NoiseAlert(0,217);


				while (GetActorProperty(169,APROP_Health) > 1000)
				{
					delay(35);
					if((getactorZ(0)>>16) < 300 && (GetActorProperty(0,APROP_Health)) > 0) playsound(0,"WILHELM",CHAN_AUTO,1.0,0,0);
				}
				stage3 = 0;
			}

			if (stage4)

			{
				//log(s:"Stage 4");
				ACS_Execute(53,0); //spawn items final zone
				Thing_spawn(218,25,0,800); //soulspheres
				thing_deactivate(169);
				changefloor(209,"0CONCH01");
				changefloor(225,"0CONCH01");
				Floor_LowerByValue(209,64,8);
				PlaySound(0,"CRACKLE",CHAN_AUTO,1.0,0,0);
				radius_quake(1,10,0,512,0);
				delay(35);
				PlaySound(0,"CRACKLE",CHAN_AUTO,1.0,0,0);
				radius_quake(1,10,0,512,0);
				delay(35);
				PlaySound(0,"CRACKLE",CHAN_AUTO,1.0,0,0);
				radius_quake(1,10,0,512,0);
				delay(35);
				Floor_LowerByValue(209,32,512);
				Floor_LowerByValue(225,32,512);
				radius_quake(2,35,0,512,0);
				teleportOther(169,183,0);

				delay(35);
				Sector_SetDamage(209,1000,17,1,256);
				Sector_SetDamage(225,1000,17,1,256);
				thing_Activate(169);
				teleportOther(169,183,0);
				while (GetActorProperty(169,APROP_Health) > 2)
				{
					delay(35);
					if((getactorZ(0)>>16) < 300 && (GetActorProperty(0,APROP_Health)) > 0) playsound(0,"WILHELM",CHAN_AUTO,1.0,0,0);
				}

				stage4 = 0;
				//log(s:"Stage 4 = 0");
			}

			if(GetActorProperty(169,APROP_Health) > 1) delay(70);
			else
			{
				deathknight_alive = 0;
				SetMusicVolume(0.8);
				delay(35);
				SetMusicVolume(0.6);
				delay(35);
				SetMusicVolume(0.4);
				delay(35);
				SetMusicVolume(0.2);
				delay(35);
				SetMusic("CATACOMB");
				delay(35);
				SetMusicVolume(1.0);

				log(s:"Rest in peace... Kro-Bakul.");

				Floor_LowerToLowest(196, 64);
				//teleportOther(169,183,0);

				delay(140);
				Floor_RaiseByvalue(210,8,16);
				changefloor(210,"GATE1");
				SetLineSpecial(211,70,212,0);
				Sector_SetDamage(175,0,0,0,0);
				Sector_SetDamage(225,0,0,0,0);
				door_open(224,16,0);

			}
				x = GetActorX(223);
				y = GetActorY(223);
				z = GetActorZ(223);
				spawn("RSWORD",x,y,z,0,0);



		}
	}
	//log(s:"Terminate script");
}

script 52 (void) //lightning
{
	int first;
	int second;
	int third;
	int fourth;

	while(stage2)
	{
		delay(70);
	first = random(0,9);
	second = random(0,9);
	third = random(0,9);
	fourth = random(0,9);
	if (first > 6) thing_activate(179);
	delay(10);
	if (second > 6) thing_activate(180);
	delay (15);
	if (third > 6) thing_activate(181);
	delay(10);
	if (fourth > 6) thing_activate(182);
	delay (35);
	}

	Thing_Deactivate(179);
	Thing_Deactivate(180);
	Thing_Deactivate(181);
	Thing_Deactivate(182);
}

