script 1 (void) //crackshot - toggle sniper
{
	//if (cover == 1) cover = 0;
	//else
	 cover = 1;

	//log(s:"cover = ", i:cover);

	while (cover)
	{

		delay (random(250, 500));
		if (!CheckActorFloorTexture(0,"0ROCKR01") && !CheckActorFloorTexture(0,"F_SKY1"))
		{
			cover = 0;
			//log(s:"Floor changed cover, cover = ", i:cover);
			break;
		}
		playsound(0,"SNIPE",CHAN_AUTO,1.0, ATTN_NONE);
		potshot = 1;
		hit = random(0,10);
		if (hit > 3)
		{
			delay(10);
			damageactor(0, 0,16,16,random(20,60),MOD_UNKNOWN);
			playsound(0,"IMPACT",CHAN_AUTO,1.0, ATTN_NONE);
		}
		else playsound(0,"RICOCHET",CHAN_AUTO,1.0, ATTN_NONE);
	}
}

