script 9 (void) //unchain helga if iron key
{
	if (!CheckInventory("IronKey") && chained)
	{
		StartConversation(3,YES);
	}
	if (CheckInventory("ironkey") && chained)
	{
		StartConversation (29, No);
		thing_remove(3);
		delay(35);
		ScriptCall("MyWorldHandler", "GiveHelga");

		chained = 0;

	}
}

