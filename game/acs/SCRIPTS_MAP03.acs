script 41 (void) //crackshot - toggle sniper in temple
{
	 cover = 1;

	//log(s:"cover = ", i:cover);

	while (cover)
	{

		delay (random(200, 400));
		if (!CheckActorFloorTexture(0,"0ROCKR01") && !CheckActorFloorTexture(0,"0BSKTB05") && !CheckActorFloorTexture(0,"OBRCKQ14") && !CheckActorFloorTexture(0,"0BRCKG02") && !CheckActorFloorTexture(0,"F_SKY1"))

		{
			cover = 0;
			//log(s:"Floor changed cover, cover = ", i:cover);
			break;
		}
		playsound(0,"SNIPE",CHAN_AUTO,1.0, ATTN_NONE);
		potshot = 1;
		hit = random(0,10);
		if (hit > 4)
		{
			delay(10);
			damageactor(0, 0,161,161,random(20,60),MOD_UNKNOWN);
			playsound(0,"IMPACT",CHAN_AUTO,1.0, ATTN_NONE);
		}
		else playsound(0,"RICOCHET",CHAN_AUTO,1.0, ATTN_NONE);
	}
}
