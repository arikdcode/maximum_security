script 5 (void) //piss off the gaurds
{
	if (!base_alert)
	{
		Thing_Activate(18); //generic gaurds
		Thing_Activate(19); //guard captain
		Thing_Activate(23); //boss
		Thing_Activate(36); //receptionist monk Right
		Thing_Activate(37); //receptionist monk left
		Thing_Activate(38); //Cook monk
		Thing_SetConversation(39, 19); //Ellie talks about attack
		Thing_Activate(39); //Ellie
		Thing_SetGoal(39,83,0,1); //Ellie runs for her life!
		Thing_Activate(50); //clerk guard
		Thing_Activate(53); //Zombies
		Thing_Activate(54); //Demons
		Thing_Activate(68); //Bunker Guard 2
		NoiseAlert(0,68);
		SetActorProperty(54,APROP_Friendly,0); //demons
		if (CheckActorProperty(68,APROP_Friendly,0)) SetActorProperty(68,APROP_Health,80); //set guard health to standard amount if not an ally

		Line_SetBlocking(65,0,BLOCKF_MONSTERS); //secret cave line allow monsters to pass

		Floor_RaiseByValue(82,16,64); //open front door


		Floor_LowerToLowest(60,16);//turrets revealed
		if (!Office_Open) Ceiling_RaiseByValue(63,32,224); //raise bars manager's office
		Office_Open = 1;



		Thing_Remove(49);
		Thing_Spawn(51,3,180,52);
		SetActorProperty(25,APROP_Friendly,0); //patrolling guard
		SetActorProperty(40,APROP_Friendly,0); //patrolling monk library
		SetActorProperty(72,APROP_Friendly,0); //patrolling guards

		log(s:"Guess we're doing this the hard way.");

		SetMusic("SOULRIPP",0); //combat music
		base_alert = 1;
	}
}

script 6 (void) //take player's stuff away
{
	if (!weapons_taken && base_alert) log(s:"No point dropping off my weapons now.");
	else if (weapons_taken && base_alert) log(s:"Damnit, it's locked tight.");
	else if (weapons_taken && base_alert) log(s:"Damnit, it's locked tight.");
	if (!weapons_taken && !base_alert)
	{
	weapons_taken = 1;
	ClearInventory();
	GiveInventory("fist", 1);
	Floor_RaiseByValue(82,16,64); //open front door
	SetActorProperty(19,APROP_Friendly,1);
	thing_activate(19);
	Thing_SetConversation(19,4);
	delay(10);
	Thing_SetGoal(19,20,0,0);
	delay(70);
	thing_Deactivate(19);
	SetActorProperty(19,APROP_Friendly,0);
	}

}

